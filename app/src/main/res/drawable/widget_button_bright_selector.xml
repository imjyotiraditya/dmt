<?xml version="1.0" encoding="utf-8"?>
<!--
    Bright TuiKey background:
    Normal: Solid tui_fg (#C6CBCC) with tui_fg stroke.
    Pressed: 40% transparent surface (#66131415) with tui_line stroke.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#66131415" />
            <stroke android:width="1dp" android:color="@color/tui_line" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/tui_fg" />
            <stroke android:width="1dp" android:color="@color/tui_fg" />
        </shape>
    </item>
</selector>
